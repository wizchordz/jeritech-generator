auto-install-peers=false
strict-peer-dependencies=false

# Hoist Expo / Babel / Metro packages to the workspace root node_modules so
# that the Metro transform worker (which runs from pnpm's virtual store) can
# resolve them via normal Node.js require() — without this, Metro crashes with
# "Cannot find module 'babel-preset-expo'" even though it IS installed under
# artifacts/mobile/node_modules.
public-hoist-pattern[]=babel-preset-expo
public-hoist-pattern[]=@expo/metro-config
public-hoist-pattern[]=@expo/cli
public-hoist-pattern[]=expo
public-hoist-pattern[]=expo-*
public-hoist-pattern[]=@babel/core
public-hoist-pattern[]=@babel/runtime
public-hoist-pattern[]=@babel/parser
public-hoist-pattern[]=@babel/generator
public-hoist-pattern[]=@babel/traverse
public-hoist-pattern[]=@babel/types
public-hoist-pattern[]=babel-plugin-*
public-hoist-pattern[]=metro
public-hoist-pattern[]=metro-*
public-hoist-pattern[]=react-native-worklets
public-hoist-pattern[]=react-native-reanimated
